# ---------------------------
# Gmail
# ---------------------------
GMAIL__USER_ID=me
GMAIL__CREDENTIALS_PATH=credentials/credentials.json
GMAIL__TOKEN_PATH=token.json
GMAIL__SCOPES=["https://www.googleapis.com/auth/gmail.readonly","https://www.googleapis.com/auth/gmail.modify","https://www.googleapis.com/auth/gmail.compose"]

# ---------------------------
# LLM (OpenAI-compatible)
# ---------------------------
LLM__API_KEY=your-openai-api-key
LLM__BASE_URL=https://api.openai.com/v1
LLM__MODEL=gpt-4.1-mini
LLM__TEMPERATURE=0.2
LLM__MAX_TOKENS=700
LLM__DEFAULT_TONE=formal
LLM__DEFAULT_LANGUAGE=en

# ---------------------------
# Filters
# ---------------------------
FILTERS__ONLY_UNREAD=true
FILTERS__AFTER_DATE=2026-05-01T00:00:00Z
FILTERS__SENDER_FILTER=
FILTERS__EXCLUDE_PROMOTIONS=true
FILTERS__EXCLUDE_NOREPLY=true
FILTERS__MAX_EMAILS=20

# ---------------------------
# Database and logs
# ---------------------------
DATABASE__SQLITE_PATH=data/email_workflow.db
PROMPT_FILE=app/config/prompts.yaml
LOG_FILE=logs/app.log
PROCESS_LIMIT=20
