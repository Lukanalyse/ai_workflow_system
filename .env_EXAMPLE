# =============================================================
#  AI Email Assistant — copy this file to `.env` and fill it in
# =============================================================
# You only need ONE of the two API keys below. The app auto-selects
# the provider based on which key is set (override with LLM_PROVIDER).

# --- LLM provider ------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: force a provider ("openai" or "anthropic"). Leave blank for auto.
LLM_PROVIDER=

# Optional: model override. Defaults: gpt-4.1-mini (openai) / claude-opus-4-8 (anthropic)
LLM_MODEL=

# Optional: sampling temperature 0.0–1.0 (blank = provider default). Also a
# slider on Settings → AI.
LLM_TEMPERATURE=

# --- Usage / cost ------------------------------------------------------------
# Monthly spend budget (USD) shown on the in-app Usage dashboard. Default: 5.0
MONTHLY_BUDGET=5.0

# --- Email sending (OFF by default) ------------------------------------------
# When true, a "Send email" button appears and the app requests the gmail.send
# scope. You can toggle this from Settings → Gmail; enabling it asks you to
# reconnect Gmail to re-consent. Leave false to keep the safe draft-only flow.
ENABLE_EMAIL_SENDING=false

# --- Gmail -------------------------------------------------------------------
# Path to your Google OAuth client file (Desktop app type recommended). You can
# also upload this file directly from Settings → Gmail instead of placing it.
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json

# Where Google sends the user back after consent. Must match an authorized
# redirect URI on the OAuth client. Leave default for local/Docker use.
OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ----------------------------------------------------------------------------
# Everything above can also be configured from the in-app Settings page and the
# first-run setup wizard — no terminal or manual login.py step required.
# Advanced legacy options (LLM__BASE_URL, FILTERS__*, DATABASE__*) still work
# if present, but are not required.
# ----------------------------------------------------------------------------
