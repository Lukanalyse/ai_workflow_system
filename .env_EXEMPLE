# ---------------------------
# LLM (OpenAI-compatible)
# ---------------------------
LLM__API_KEY=your-openai-api-key
LLM__BASE_URL=https://api.openai.com/v1
LLM__MODEL=gpt-4.1-mini
LLM__TEMPERATURE=0.2
LLM__MAX_TOKENS=700
LLM__DEFAULT_TONE=formal
LLM__DEFAULT_LANGUAGE=en

# ---------------------------
# Email Filters
# Use JSON arrays for lists.
# ---------------------------
FILTERS__ONLY_UNREAD=true
FILTERS__AFTER_DATE=2026-05-01T00:00:00Z
FILTERS__SENDER_WHITELIST=[]
FILTERS__SENDER_BLACKLIST=["noreply@example.com"]
FILTERS__KEYWORDS=[]
FILTERS__EXCLUDE_NEWSLETTERS=true
FILTERS__EXCLUDE_AUTOMATED=true

# ---------------------------
# App / Database
# ---------------------------
DATABASE__SQLITE_PATH=data/email_workflow.db
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
PROMPT_FILE=app/config/prompts.yaml
LOG_FILE=logs/app.log
PROCESS_LIMIT=50

# ---------------------------
# Optional Gmail test script
# app/email/test_gmail_connection.py
# ---------------------------
GMAIL_USER_ID=me
GMAIL_ACCESS_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
